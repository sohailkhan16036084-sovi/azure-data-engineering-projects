							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"dataflow": {
								"referenceName": "DF_Combine_Sales",
								"type": "DataFlowReference",
								"parameters": {},
								"datasetParameters": {
									"online": {},
									"stores": {},
									"app": {},
									"sinktosql": {}
								}
							},
							"staging": {},
							"compute": {
								"coreCount": 8,
								"computeType": "General"
							},
							"traceLevel": "Fine"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"parameters": {
					"ProcessingDate": {
						"type": "string",
						"defaultValue": "2024-03-15"
					}
				},
				"annotations": [],
				"lastPublishTime": "2026-02-27T15:02:09Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/online_sales')]",
				"[concat(variables('factoryId'), '/datasets/stores_sales')]",
				"[concat(variables('factoryId'), '/datasets/app_sales')]",
				"[concat(variables('factoryId'), '/dataflows/DF_Combine_Sales')]"
			]
		},
